# Finance Tracker — Environment Variables
# Copy this file to .env and fill in your values.
# All variables have sensible defaults for local development.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/finance

# Set to true to log every SQL statement to the terminal (very noisy — use in .env.local only)
DB_ECHO=false

# ── Redis / RQ ────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# Max wall-clock seconds a background job may run (default: 1800 = 30 min)
JOB_TIMEOUT_SECONDS=1800

# ── MinIO / S3-compatible Storage ─────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
BUCKET_NAME=bank-statements

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Session / Auth ────────────────────────────────────────────────────────────
SESSION_COOKIE_NAME=finance_tracker_session

# Session lifetime in seconds (default: 604800 = 7 days)
SESSION_MAX_AGE_SECONDS=604800

# Set to "true" in production (requires HTTPS)
SESSION_COOKIE_SECURE=false

# PBKDF2 iteration count — higher = more secure but slower
# 600 000 is the 2023 OWASP recommendation for PBKDF2-SHA256
PASSWORD_HASH_ITERATIONS=600000

# Minimum password length enforced at registration
PASSWORD_MIN_LENGTH=8

# ── LLM (Ollama) ──────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=deepseek-r1:7b

# Max characters per extraction chunk (tune to your model's context window)
LLM_MAX_CHUNK_CHARS=3500

# Max transactions per categorization batch
LLM_CATEGORIZE_BATCH_SIZE=8

# Retry attempts on empty/unparseable LLM output
LLM_RETRY_ATTEMPTS=2

# ── Frontend ──────────────────────────────────────────────────────────────────
# Used by Next.js to reach the backend (set in frontend/.env.local)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
